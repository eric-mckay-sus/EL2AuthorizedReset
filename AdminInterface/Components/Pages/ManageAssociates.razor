@page "/manage-associates"
@using AdminInterface
@inject IDbContextFactory<AuthResetDbContext> DbFactory
@rendermode InteractiveServer

<PageTitle>Manage Associates</PageTitle>

<h1>Add/Remove an Associate</h1>

<EditForm Model="@associate" OnValidSubmit="@HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div>
        <label for="name">Associate Name:</label>
        <InputText id="name" @bind-Value="associate.Name" />
    </div>
    <div>
        <label for="assocNum">Associate Number:</label>
        <InputNumber id="assocNum" @bind-Value="associate.AssocNum" />
    </div>
    <div>
        <label for="badgeNum">Badge Number:</label> @* Need validation for no duplicates bc PK*@
        <InputNumber id="badgeNum" @bind-Value="associate.BadgeNum" />
    </div>
    @* Leave out admin privileges, we don't want admins to be able to create other admins *@

    <button type="submit" class="btn btn-primary">Add Associate</button>
</EditForm>

@if (DataView.Count > 0) {
    <UniversalTable T="Associate" Items="DataView" OnDelete="HandleDelete" />
}

<DeleteDialog @ref="deleteDialog" />

@code {
    private Associate associate = new Associate();
    private List<Associate> DataView = [];
    private DeleteDialog deleteDialog = default!;

    protected override async Task OnInitializedAsync(){
        await LoadData();
    }

    private async Task LoadData(){
        using var context = DbFactory.CreateDbContext();
        DataView = await context.Set<Associate>().ToListAsync();
    }

    private async Task HandleValidSubmit()
    {
        using var context = DbFactory.CreateDbContext();
        
        context.AssociateInfo.Add(associate);
        await context.SaveChangesAsync();

        associate = new Associate();
        await LoadData();
    }

    private async Task HandleDelete(Associate item)
    {
        if (await deleteDialog.ConfirmAsync(item, item.Name ?? item.BadgeNum.ToString())) {
            using var context = DbFactory.CreateDbContext();
            context.Set<Associate>().Remove(item);
            await context.SaveChangesAsync();
            await LoadData();
        }
    }
}
