@page "/"
@inherits HomeBase

<PageTitle>Home</PageTitle>

<h1>Historical Resets</h1>

<div class="filter-panel mb-3 p-3 border rounded bg-light">
    <div class="row g-3">
        <div class="col-2">
            <label class="form-label">Associate #</label>
            <input type="number" 
                   class="form-control"
                   @bind-value="FilterAssocNum.Value" 
                   @bind-value:event="oninput" 
                   placeholder="(e.g. 2964)" />
        </div>

        <div class="col-3">
            <label class="form-label">Associate Name</label>
            <input type="text" 
                   class="form-control"
                   @bind-value="FilterAssocName.Value" 
                   @bind-value:event="oninput" 
                   placeholder="Enter associate name..." />
        </div>

        <div class="col-2">
            <label class="form-label">CMMS #</label>
            <input type="number" 
                   class="form-control"
                   @bind-value="FilterCmmsNum.Value" 
                   @bind-value:event="oninput" 
                   placeholder="Enter complete CMMS number" />
        </div>

        <div class="col-2">
            <label class="form-label">Line Name</label>
            <input type="text" 
                   class="form-control"
                   @bind-value="FilterLineName.Value" 
                   @bind-value:event="oninput" 
                   placeholder="Enter any part of the line name" />
        </div>

        <div class="col-2">
            <label class="form-label">Authorization</label>
            <select class="form-control" 
                    value="@FilterIsAuthorized.Value?.ToString().ToLower()" 
                    @oninput="@(e => {
                        var val = e.Value?.ToString();
                        FilterIsAuthorized.Value = string.IsNullOrEmpty(val) ? null : bool.Parse(val);
                    })">
                <option value="">All</option>
                <option value="true">Authorized</option>
                <option value="false">Unauthorized</option>
            </select>
        </div>

        <div class="col-2">
            <label class="form-label">From Date</label>
            <input type="date" 
                   class="form-control"
                   value="@FilterStartDate.Value?.ToString("yyyy-MM-dd")" 
                   @oninput="@(e => FilterStartDate.Value = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
        </div>

        <div class="col-md-2">
            <label class="form-label">To Date</label>
            <input type="date" 
                   class="form-control"
                   value="@FilterEndDate.Value?.ToString("yyyy-MM-dd")" 
                   @oninput="@(e => FilterEndDate.Value = string.IsNullOrEmpty(e.Value?.ToString()) ? null : DateTime.Parse(e.Value.ToString()!))" />
        </div>

        <div class="col-12 d-flex justify-content-end gap-3">
            <button class="btn btn-outline-secondary" @onclick="ClearAllFilters">Clear</button>
            <button class="btn btn-primary" @onclick="LoadData">Execute</button>
        </div>
    </div>
</div>

@if (IsLoading){
    <Spinner Color="SpinnerColor.Primary" />
} else {
    @if(DataView.Count == 0){
        <h3>No records matched your criteria.</h3>
    } else{
        <UniversalTable T="Reset" Items="DataView" OnSort="ToggleSort" IsStale="IsStale" GetSortIcon="GetSortIcon" />
    }
}
